# データベース設定
DATABASE_URL=sqlite:///./transcript_minutes_app.db

# JWT設定
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI API設定
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=2000

# アプリケーション設定
APP_NAME=Transcript Minutes API
APP_VERSION=1.0.0
DEBUG=False

# ログ設定
LOG_LEVEL=INFO
LOG_FILE=transcript_minutes_app.log

# オプション環境変数
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=60
RELOAD=True
HOST=0.0.0.0
PORT=8001
